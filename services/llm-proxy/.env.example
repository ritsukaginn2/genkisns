PORT=8787
HOST=0.0.0.0
# development | production. In production, startup fails fast on unsafe config.
NODE_ENV=development
# debug | info | warn | error
LOG_LEVEL=info
# SQLite database file (created on first run; needs Node >= 22 for node:sqlite).
DATA_FILE=./data/llm-proxy.db

# stub keeps local development runnable without a model key.
# Use openai-compatible for a real hosted provider.
LLM_PROVIDER=stub
LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# --- Admin operators (management API) ---
# Seeds the first owner account on startup when no admin exists yet.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Admin session lifetime (hours).
SESSION_TTL_HOURS=168
# Comma-separated browser origins allowed for CORS; '*' is dev-only.
CORS_ALLOWED_ORIGINS=*

# --- Device (end-user) auth ---
# When true, device endpoints require the X-Device-Token issued at registration.
REQUIRE_DEVICE_TOKEN=false

# Legacy shared-secret moderation endpoint (/internal). Prefer the admin API.
INTERNAL_TOKEN=change-me
REQUEST_BODY_LIMIT_BYTES=65536
WORKER_CONCURRENCY=2
JOB_TIMEOUT_MS=30000
INSTALLATION_RATE_LIMIT_PER_MINUTE=8
IP_RATE_LIMIT_PER_MINUTE=30
# Only enable when running behind a trusted reverse proxy; otherwise X-Forwarded-For
# can be spoofed to bypass the per-IP rate limit.
TRUST_PROXY=false
DAILY_JOB_LIMIT=500
DAILY_BUDGET_CENTS=500
ESTIMATED_JOB_COST_CENTS=2
MAX_TEXT_LENGTH=2000
MAX_COMMENTS=5
MAX_COMMENT_LENGTH=160
MAX_FRIENDS=12
# Staggered delivery pacing (real-person feel): delay[i] = first + i*gap, capped.
COMMENT_FIRST_DELAY_SECONDS=4
COMMENT_DELAY_GAP_SECONDS=18
COMMENT_MAX_DELAY_SECONDS=600
SAFETY_BLOCKLIST=BLOCK_ME,自杀,杀人,诈骗
